NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Fonema.ia (llamadas agenticas)
FONEMA_API_URL=
FONEMA_API_KEY=
FONEMA_SALES_AGENT_ID=
FONEMA_FOLLOWUP_AGENT_ID=

# Resend (correos)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# PowerApps webhook / callback (opcional)
POWERAPPS_WEBHOOK_SECRET=

# Delivery confirmation
# Local/demo: 60000 = 1 min por dia emulado. Produccion: 86400000 = 1 dia real.
TIME_COMPRESSION_DAY_MS=60000
CONFIRMATION_TOKEN_SECRET=
# Pagina del frontend donde el gerente confirma la entrega
FRONTEND_CONFIRMATION_URL=http://localhost:4200/delivery-confirmation

# Vercel Cron (Vercel lo inyecta automaticamente al definir crons en vercel.json)
CRON_SECRET=

# Batch calling (campañas de sales-calls) — pacing por defecto cuando el request no lo especifica.
# Dos perillas independientes + ventana de contacto (control de cumplimiento, no solo UX).
# El techo real de concurrencia es el de la cuenta Fonema (~500); nunca excederlo.
CALL_BATCH_MAX_CONCURRENT=20
CALL_BATCH_PER_HOUR=60
CALL_BATCH_BUSINESS_START_HOUR=8
CALL_BATCH_BUSINESS_END_HOUR=20
CALL_BATCH_TIMEZONE=America/Bogota
