NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Fonema.ia (llamadas agenticas)
FONEMA_API_URL=
FONEMA_API_KEY=
FONEMA_SALES_AGENT_ID=
FONEMA_FOLLOWUP_AGENT_ID=

# Resend (correos)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# PowerApps webhook / callback (opcional)
POWERAPPS_WEBHOOK_SECRET=

# Delivery confirmation
# Local/demo: 60000 = 1 min por dia emulado. Produccion: 86400000 = 1 dia real.
TIME_COMPRESSION_DAY_MS=60000
CONFIRMATION_TOKEN_SECRET=
# Pagina del frontend donde el gerente confirma la entrega
FRONTEND_CONFIRMATION_URL=http://localhost:4200/delivery-confirmation

# Vercel Cron (Vercel lo inyecta automaticamente al definir crons en vercel.json)
CRON_SECRET=
