{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/delivery-confirmation/cron/process-due",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/sales-calls/cron/dispatch",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/activation-follow-up/cron/process-reminders",
      "schedule": "0 13 * * *"
    }
  ]
}
